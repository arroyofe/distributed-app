# --- DATABASE (MySQL) ---
DB_USER=appuser
DB_PASSWORD=app-pass-strong
DB_ROOT_PASSWORD=rootpass
DB_NAME=appdb
DB_HOST=db
DB_PORT=3306

# --- TIMEZONE ---
TZ=UTC

# --- SPRING APP ---
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/appdb?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=utf8
SPRING_DATASOURCE_USERNAME=appuser
SPRING_DATASOURCE_PASSWORD=app-pass-strong

# --- PYTHON SERVICES ---
PY_DB_USER=appuser
PY_DB_PASSWORD=app-pass-strong
PY_DB_NAME=appdb
PY_DB_HOST=db
PY_DB_PORT=3306